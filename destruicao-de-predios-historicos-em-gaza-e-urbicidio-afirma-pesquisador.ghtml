  (() => {
    const { searchParams } = new URL(document.URL);
    const referrer = document.referrer || null
    let previousPage = "";

    if (searchParams.get("utm_source") && searchParams.get("utm_medium")) {
      const utmSource = searchParams.get("utm_source");
      const utmMedium = searchParams.get("utm_medium");
      const isCampaign = ["cpc", "banner", "em", "email", "newsl"].includes(
        utmMedium
      );
      const merge = `${utmSource} / ${utmMedium}`;

      previousPage = isCampaign ? `Campanha - ${merge}` : merge;
    } else {
      if (!referrer) {
        previousPage = "(direto/indefinido)";
      } else {
        const { pathname } = new URL(referrer);

        if (referrer.includes(`galileu + '.globo.com'`)) {
          previousPage =
            pathname === "/"
              ? `galileu + ' - Capa'`
              : `galileu + ' - outros'`;
        } else {
          previousPage = referrer;
        }
      }
    }

    let originPage = null;

    if (
      referrer &&
      (referrer.includes("galileu") || referrer.includes("Campanha"))
    ) {
      originPage = "semente";
    } else if (previousPage.includes(".globo.com")) {
      originPage = "*.globo.com";
    } else {
      originPage = "viral";
    }

    window.utag_data = window.utag_data || {};
    window.utag_data = {
      ...window.utag_data,
      produto: "GalileuBS",
      editoria_path: "sociedade",
      hrModificacao: "11",
      hrPublicacao: "11",
      paginaAnterior: previousPage,
      dtPublicacao: "20240221",
      origem: originPage,
      entidades: ""
    };
  })();
